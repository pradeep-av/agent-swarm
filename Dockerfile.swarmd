# syntax=docker/dockerfile:1

# ── Build stage ──────────────────────────────────────────────────────────────
FROM golang:1.26-alpine AS builder

WORKDIR /src

# Cache dependency downloads as a separate layer.
COPY go.mod go.sum ./
RUN go mod download

COPY cmd/swarmd/    cmd/swarmd/
COPY internal/      internal/
COPY pkg/           pkg/

RUN CGO_ENABLED=0 GOOS=linux \
    go build \
             -ldflags="-s -w" \
             -o /out/swarmd \
             ./cmd/swarmd

# ── Runtime stage ─────────────────────────────────────────────────────────────
FROM alpine:3.20

RUN apk --no-cache add ca-certificates tzdata

COPY --from=builder /out/swarmd /usr/local/bin/swarmd

# WebSocket agent connections + status UI
EXPOSE 8080

ENTRYPOINT ["swarmd"]
CMD ["-addr", ":8080"]
